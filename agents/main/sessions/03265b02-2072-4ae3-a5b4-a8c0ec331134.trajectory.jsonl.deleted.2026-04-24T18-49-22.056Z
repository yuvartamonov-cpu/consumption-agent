evision-checked mutations, and user-facing emergence.","filePath":"~/.npm-global/lib/node_modules/openclaw/skills/taskflow/SKILL.md","baseDir":"~/.npm-global/lib/node_modules/openclaw/skills/taskflow","source":"openclaw-bundled","sourceInfo":{"baseDir":"~/.npm-global/lib/node_modules/openclaw/skills/taskflow","origin":"top-level","path":"~/.npm-global/lib/node_modules/openclaw/skills/taskflow/SKILL.md","scope":"project","source":"openclaw-bundled"},"disableModelInvocation":false,"available":true},{"id":"taskflow-inbox-triage","name":"taskflow-inbox-triage","description":"Example TaskFlow authoring pattern for inbox triage. Use when messages need different treatment based on intent, with some routes notifying immediately, some waiting on outside answers, and others rolling into a later summary.","filePath":"~/.npm-global/lib/node_modules/openclaw/skills/taskflow-inbox-triage/SKILL.md","baseDir":"~/.npm-global/lib/node_modules/openclaw/skills/taskflow-inbox-triage","source":"openclaw-bundled","sourceInfo":{"baseDir":"~/.npm-global/lib/node_modules/openclaw/skills/taskflow-inbox-triage","origin":"top-level","path":"~/.npm-global/lib/node_modules/openclaw/skills/taskflow-inbox-triage/SKILL.md","scope":"project","source":"openclaw-bundled"},"disableModelInvocation":false,"available":true},{"id":"tmux","name":"tmux","description":"Remote-control tmux sessions for interactive CLIs by sending keystrokes and scraping pane output.","filePath":"~/.npm-global/lib/node_modules/openclaw/skills/tmux/SKILL.md","baseDir":"~/.npm-global/lib/node_modules/openclaw/skills/tmux","source":"openclaw-bundled","sourceInfo":{"baseDir":"~/.npm-global/lib/node_modules/openclaw/skills/tmux","origin":"top-level","path":"~/.npm-global/lib/node_modules/openclaw/skills/tmux/SKILL.md","scope":"project","source":"openclaw-bundled"},"disableModelInvocation":false,"available":true},{"id":"weather","name":"weather","description":"Get current weather and forecasts via wttr.in or Open-Meteo. Use when: user